ENV=DEV_LOCAL
SECRET_KEY=django-insecure-changemechangemechangemechangemechangemechangeme

# Disable HTTPS redirects for local development
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False

DJANGO_DB_HOST=localhost
DJANGO_DB_NAME=salesiq
DJANGO_DB_USER=postgres
DJANGO_DB_PASSWORD=postgres
DJANGO_DB_PORT=5432
REDIS_URL=redis://localhost:6379

# Salesforce integration
# SF_AUTH_METHOD: client_credentials (recommended) | password_oauth | security_token
SF_AUTH_METHOD=client_credentials

# --- client_credentials (server-to-server; no user/password) ---
# Connected App must have Client Credentials Flow enabled with a Run-As user.
# SF_DOMAIN = your My Domain host WITHOUT the trailing ".salesforce.com"
#   (instance https://acme-dev-ed.develop.my.salesforce.com -> acme-dev-ed.develop.my)
SF_DOMAIN=your-domain.develop.my
SF_CONSUMER_KEY=your-connected-app-consumer-key
SF_CONSUMER_SECRET=your-connected-app-consumer-secret

# --- password_oauth / security_token fallbacks ---
# For these, set SF_DOMAIN to "login" (prod / Developer Edition) or "test" (sandbox).
SF_USERNAME=your-salesforce-login@example.com
SF_PASSWORD=your-salesforce-password
SF_SECURITY_TOKEN=your-security-token
